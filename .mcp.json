{
  "mcpServers": {
    "context7": {
        "type": "stdio",
        "command": "npx",
        "args": [
            "-y",
            "@upstash/context7-mcp"
        ]
        },
        "markitdown": {
            "type": "stdio",
            "command": "uvx",
            "args": [
                "markitdown-mcp==0.0.1a4"
            ]
        },
        "microsoftdocs": {
                "type": "http",
                "url": "https://learn.microsoft.com/api/mcp"
        },
        "github": {
                "type": "http",
                "url": "https://api.github.com/mcp",
                "headers": {
                    "Authorization": "Bearer ${GITHUB_TOKEN}"
                }
        }
    }
}
